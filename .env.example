# Django (override in production when using docker-compose)
SECRET_KEY=change-me-in-production
DEBUG=0
ALLOWED_HOSTS=localhost,127.0.0.1
# Required when using HTTPS behind a reverse proxy (e.g. nginx-proxy-manager):
# CSRF_TRUSTED_ORIGINS=https://your-domain.com

# PostgreSQL (required for docker-compose: copy to .env, set POSTGRES_PASSWORD)
# For local run without Docker: set POSTGRES_DB (and optionally POSTGRES_HOST/POSTGRES_PORT); else SQLite
POSTGRES_USER=planner
POSTGRES_PASSWORD=
POSTGRES_DB=planner
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# Static files (optional; default: BASE_DIR/staticfiles)
# STATIC_ROOT=/app/staticfiles

# GlitchTip error tracking (optional; SDK is inactive when unset)
# GLITCHTIP_DSN=https://...@app.glitchtip.com/123
# GLITCHTIP_TRACES_SAMPLE_RATE=0.01
# GLITCHTIP_RELEASE=1.0.0
# GLITCHTIP_ENVIRONMENT=production

# LogTide structured logging (optional; inactive when unset)
# LOGTIDE_API_URL=http://localhost:8080
# LOGTIDE_API_KEY=lp_your_api_key_here
# LOGTIDE_SERVICE_NAME=food-purchase-planner-web  # в docker-compose задаётся per-container

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# SOCKS5 proxy for Telegram API (required — bot fails to start without it)
SOCKS5_PROXY_URL=socks5://user:pass@host:port

# MCP server authentication
MCP_AUTH_TOKEN=

# MCP OAuth2 (for Claude Desktop connector; optional if using MCP_AUTH_TOKEN)
# MCP_OAUTH_CLIENT_ID=
# MCP_OAUTH_CLIENT_SECRET=
